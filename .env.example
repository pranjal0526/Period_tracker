# Copy this file to .env.local and fill in your real values.
# Required for database reads/writes
MONGODB_URI=

# Canonical app URL
# Local: http://localhost:3000
# Production example: https://your-app.vercel.app or https://your-domain.com
NEXTAUTH_URL=http://localhost:3000

# Required in production. Generate a long random secret.
NEXTAUTH_SECRET=

# Google OAuth app credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional for live AI wording. Without it, the app falls back to simpler on-device summaries.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Required in production. Use a long random value and keep it stable.
ENCRYPTION_SALT=
